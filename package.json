{
  "name": "endpoint-arena",
  "version": "1.0.0",
  "description": "AI models predict clinical trial outcomes",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24.14.0 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "predev": "npx tsx scripts/local-postgres.ts ensure",
    "dev": "next dev --turbopack",
    "dev:local": "node scripts/start-local-dev.js",
    "dev:webpack": "next dev --webpack",
    "predev:all": "npx tsx scripts/local-postgres.ts ensure",
    "dev:all": "concurrently \"next dev --turbopack\" \"drizzle-kit studio\"",
    "dev:all:webpack": "concurrently \"next dev --webpack\" \"drizzle-kit studio\"",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "npm run typecheck",
    "knip": "knip --include dependencies,unlisted,binaries,exports,files --reporter compact",
    "check": "npm run typecheck && npm run build && npm run knip",
    "audit:prod": "npm audit --omit=dev",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:push-local": "node scripts/run-with-env.js .env.local -- npx drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-local": "node scripts/run-with-env.js .env.local -- npx drizzle-kit migrate",
    "db:create-local": "node scripts/run-with-env.js .env.local -- npx tsx scripts/create-env-db.ts",
    "db:check-local": "node scripts/run-with-env.js .env.local -- npx tsx scripts/check-local.ts",
    "db:reset-local-trial-monitor": "node scripts/run-with-env.js .env.local -- npx tsx scripts/reset-local-trial-monitor.ts",
    "db:wipe-local-trial-monitor": "node scripts/run-with-env.js .env.local -- npx tsx scripts/wipe-local-trial-monitor.ts",
    "db:cleanup-local-mock-market-data": "node scripts/run-with-env.js .env.local -- npx tsx scripts/cleanup-local-mock-market-data.ts",
    "db:cleanup-admin-ai-timeout-snapshots-local": "node scripts/run-with-env.js .env.local -- npx tsx scripts/cleanup-admin-ai-timeout-snapshots.ts",
    "db:status-local-postgres": "npx tsx scripts/local-postgres.ts status",
    "db:start-local-postgres": "npx tsx scripts/local-postgres.ts start",
    "db:stop-local-postgres": "npx tsx scripts/local-postgres.ts stop",
    "db:switch-local-postgres": "npx tsx scripts/local-postgres.ts switch",
    "db:add-market-runtime-config": "npx tsx scripts/add-market-runtime-config.ts",
    "db:audit-market-v2": "node scripts/run-with-env.js .env.local -- npx tsx scripts/audit-market-db-v2.ts",
    "db:seed": "npm run db:import-phase2",
    "db:import-phase2:dry-run": "npx tsx scripts/import-phase2-trials.ts",
    "db:import-phase2": "npx tsx scripts/import-phase2-trials.ts --apply",
    "db:download-clinicaltrials-snapshot": "node scripts/run-with-env.js .env.local -- npx tsx scripts/download-clinicaltrials-gov-snapshot.ts",
    "db:export-trial-public-state": "node scripts/run-with-env.js .env.local -- npx tsx scripts/export-trial-public-state.ts",
    "db:import-trial-public-state": "npx tsx scripts/import-trial-public-state.ts --input-file",
    "db:export-admin-ai-automation-packet": "node scripts/run-with-env.js .env.local -- npx tsx scripts/export-admin-ai-automation-packet.ts",
    "db:import-admin-ai-automation-decisions": "node scripts/run-with-env.js .env.local -- npx tsx scripts/import-admin-ai-automation-decisions.ts",
    "db:download-public-company-reference": "npx tsx scripts/download-public-company-reference.ts",
    "db:backfill-public-sponsor-tickers": "node scripts/run-with-env.js .env.local -- npx tsx scripts/backfill-phase2-public-sponsor-tickers.ts",
    "db:export-manual-trial-outcome-queue": "node scripts/run-with-env.js .env.local -- npx tsx scripts/export-manual-trial-outcome-queue.ts",
    "db:import-manual-trial-outcomes": "node scripts/run-with-env.js .env.local -- npx tsx scripts/import-manual-trial-outcomes.ts",
    "db:sync-ai-batches-to-prod": "node scripts/run-with-env.js .env.local -- npx tsx scripts/sync-ai-batches-to-prod.ts",
    "db:extract-clinicaltrials-sponsors": "npx tsx scripts/extract-clinicaltrials-gov-sponsors.ts",
    "db:curate-clinicaltrials-sponsors": "npx tsx scripts/curate-clinicaltrials-sponsor-map.ts",
    "db:report-public-sponsors": "node scripts/run-with-env.js .env.local -- npx tsx scripts/report-public-sponsor-coverage.ts",
    "db:sync-clinicaltrials": "node scripts/run-with-env.js .env.local -- npx tsx scripts/sync-clinicaltrials-gov.ts",
    "db:sync-clinicaltrials:from-file": "node scripts/run-with-env.js .env.local -- npx tsx scripts/sync-clinicaltrials-gov.ts --input-file",
    "ops:check-prod-alerts": "npx tsx scripts/ops-check-prod-alerts.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@auth/drizzle-adapter": "^1.11.1",
    "@google/genai": "^1.48.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.2",
    "next-auth": "^4.24.11",
    "nodemailer": "^7.0.13",
    "openai": "^6.33.0",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.10.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "knip": "^6.2.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "minimatch": "^9.0.7",
    "brace-expansion": "^2.0.3"
  }
}
