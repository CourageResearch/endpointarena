{
  "name": "endpoint-arena",
  "version": "1.0.0",
  "description": "AI models predict clinical trial outcomes",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24.14.0 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "predev": "npx tsx scripts/local-postgres.ts ensure",
    "dev": "next dev --turbopack",
    "predev:all": "npx tsx scripts/local-postgres.ts ensure",
    "dev:all": "concurrently \"next dev --turbopack\" \"drizzle-kit studio\"",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:push-local": "node scripts/run-with-env.js .env.local -- npx drizzle-kit push",
    "db:migrate": "drizzle-kit generate",
    "db:ensure-market-schema": "node scripts/ensure-market-schema.js",
    "db:create-local": "node scripts/run-with-env.js .env.local -- npx tsx scripts/create-local-db.ts",
    "db:bootstrap-local": "node scripts/run-with-env.js .env.local -- npx tsx scripts/bootstrap-local.ts",
    "db:check-local": "node scripts/run-with-env.js .env.local -- npx tsx scripts/check-local.ts",
    "db:check-local-fixture": "node scripts/run-with-env.js .env.local -- npx tsx scripts/check-local-fixture.ts",
    "db:cleanup-local-mock-market-data": "node scripts/run-with-env.js .env.local -- npx tsx scripts/cleanup-local-mock-market-data.ts",
    "db:validate-local": "node scripts/run-with-env.js .env.local -- npx tsx scripts/validate-local-pipeline.ts",
    "db:status-local-postgres": "npx tsx scripts/local-postgres.ts status",
    "db:start-local-postgres": "npx tsx scripts/local-postgres.ts start",
    "db:stop-local-postgres": "npx tsx scripts/local-postgres.ts stop",
    "db:switch-local-postgres": "npx tsx scripts/local-postgres.ts switch",
    "db:add-market-runtime-config": "npx tsx scripts/add-market-runtime-config.ts",
    "db:add-event-monitoring": "npx tsx scripts/add-event-monitoring.ts",
    "db:finalize-event-monitoring": "npx tsx scripts/finalize-event-monitoring.ts",
    "db:add-fda-prediction-usage-columns": "npx tsx scripts/add-fda-prediction-usage-columns.ts",
    "db:add-fda-prediction-provider-usage-columns": "npx tsx scripts/add-fda-prediction-provider-usage-columns.ts",
    "db:add-twitter-verification-columns": "npx tsx scripts/add-twitter-verification-columns.ts",
    "db:add-user-password-hash-column": "npx tsx scripts/add-user-password-hash-column.ts",
    "db:add-user-display-name-constraint": "npx tsx scripts/add-user-display-name-constraint.ts",
    "db:add-user-signup-location-column": "npx tsx scripts/add-user-signup-location-column.ts",
    "db:add-user-signup-state-column": "npx tsx scripts/add-user-signup-state-column.ts",
    "db:shorten-twitter-hold-12h": "npx tsx scripts/shorten-twitter-hold-to-12h.ts",
    "db:audit-market": "npx tsx scripts/audit-market-db.ts",
    "db:audit-market-v2": "node scripts/run-with-env.js .env.local -- npx tsx scripts/audit-market-db-v2.ts",
    "db:ensure-phase2-schema": "npx tsx scripts/ensure-phase2-schema.ts",
    "db:seed": "npm run db:import-cnpv",
    "db:import-cnpv:dry-run": "npx tsx scripts/import-cnpv.ts --dry-run",
    "db:import-cnpv": "npx tsx scripts/import-cnpv.ts --apply",
    "db:import-phase2:dry-run": "npx tsx scripts/import-phase2-trials.ts",
    "db:import-phase2": "npx tsx scripts/import-phase2-trials.ts --apply",
    "db:download-clinicaltrials-snapshot": "node scripts/run-with-env.js .env.local -- npx tsx scripts/download-clinicaltrials-gov-snapshot.ts",
    "db:extract-clinicaltrials-sponsors": "npx tsx scripts/extract-clinicaltrials-gov-sponsors.ts",
    "db:curate-clinicaltrials-sponsors": "npx tsx scripts/curate-clinicaltrials-sponsor-map.ts",
    "db:sync-clinicaltrials": "node scripts/run-with-env.js .env.local -- npx tsx scripts/sync-clinicaltrials-gov.ts",
    "db:sync-clinicaltrials:from-file": "node scripts/run-with-env.js .env.local -- npx tsx scripts/sync-clinicaltrials-gov.ts --input-file",
    "db:seed-fda": "npm run db:import-cnpv",
    "ops:check-prod-cutover": "npx tsx scripts/ops-check-prod-cutover.ts",
    "ops:check-prod-alerts": "npx tsx scripts/ops-check-prod-alerts.ts",
    "ops:rollback-trial-bootstrap": "npx tsx scripts/rollback-trial-bootstrap.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@auth/drizzle-adapter": "^1.11.1",
    "@google/genai": "^1.42.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "next": "^16.1.6",
    "next-auth": "^4.24.11",
    "nodemailer": "^7.0.13",
    "openai": "^6.22.0",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
