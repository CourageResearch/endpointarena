{
  "name": "endpoint-arena",
  "version": "1.0.0",
  "description": "AI models predict clinical trial outcomes",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:one-drug": "node scripts/run-with-env.js .env.one-drug.local -- next dev --webpack",
    "dev:all": "concurrently \"next dev --turbopack\" \"drizzle-kit studio\"",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:push-one-drug-local": "node scripts/run-with-env.js .env.one-drug.local -- npx drizzle-kit push",
    "db:migrate": "drizzle-kit generate",
    "db:ensure-market-schema": "node scripts/ensure-market-schema.js",
    "db:create-one-drug-local": "node scripts/run-with-env.js .env.one-drug.local -- npx tsx scripts/create-one-drug-local-db.ts",
    "db:bootstrap-one-drug-local": "node scripts/run-with-env.js .env.one-drug.local -- npx tsx scripts/bootstrap-one-drug-local.ts",
    "db:check-one-drug-local": "node scripts/run-with-env.js .env.one-drug.local -- npx tsx scripts/check-one-drug-local.ts",
    "db:add-market-runtime-config": "npx tsx scripts/add-market-runtime-config.ts",
    "db:add-cnpv-event-fields": "npx tsx scripts/add-cnpv-event-fields.ts",
    "db:add-fda-prediction-usage-columns": "npx tsx scripts/add-fda-prediction-usage-columns.ts",
    "db:add-fda-prediction-provider-usage-columns": "npx tsx scripts/add-fda-prediction-provider-usage-columns.ts",
    "db:add-twitter-verification-columns": "npx tsx scripts/add-twitter-verification-columns.ts",
    "db:add-user-password-hash-column": "npx tsx scripts/add-user-password-hash-column.ts",
    "db:add-user-display-name-constraint": "npx tsx scripts/add-user-display-name-constraint.ts",
    "db:add-user-signup-location-column": "npx tsx scripts/add-user-signup-location-column.ts",
    "db:add-user-signup-state-column": "npx tsx scripts/add-user-signup-state-column.ts",
    "db:shorten-twitter-hold-12h": "npx tsx scripts/shorten-twitter-hold-to-12h.ts",
    "db:audit-market": "npx tsx scripts/audit-market-db.ts",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:import-cnpv:dry-run": "npx tsx scripts/import-cnpv.ts --dry-run",
    "db:import-cnpv": "npx tsx scripts/import-cnpv.ts --apply",
    "db:seed-fda": "npm run db:import-cnpv"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@auth/drizzle-adapter": "^1.11.1",
    "@google/genai": "^1.42.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "next": "^16.1.6",
    "next-auth": "^4.24.11",
    "nodemailer": "^7.0.13",
    "openai": "^6.22.0",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.2",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
