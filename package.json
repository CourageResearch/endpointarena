{
  "name": "endpoint-arena",
  "version": "1.0.0",
  "description": "AI models predict clinical trial outcomes",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24.14.0 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "predev": "npx tsx scripts/local-postgres.ts ensure",
    "dev": "next dev --turbopack",
    "dev:local": "node scripts/start-local-dev.js",
    "dev:webpack": "next dev --webpack",
    "predev:all": "npx tsx scripts/local-postgres.ts ensure",
    "dev:all": "concurrently \"next dev --turbopack\" \"drizzle-kit studio\"",
    "dev:all:webpack": "concurrently \"next dev --webpack\" \"drizzle-kit studio\"",
    "build": "next build",
    "start": "node scripts/start-railway-service.js",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "npm run typecheck",
    "test": "npm run test:app && npm run test:contracts",
    "test:app": "node --import tsx --test tests/*.test.ts",
    "test:contracts": "cd contracts && hardhat test",
    "test:season4:amm": "node --import tsx --test tests/season4-ops.test.ts tests/season4-onchain.test.ts tests/season4-amm-math.test.ts tests/season4-trade-execution.test.ts tests/season4-trade-state.test.ts",
    "test:season4:amm:all": "npm run test:season4:amm && npm run test:contracts",
    "knip": "knip --include dependencies,unlisted,binaries,exports,files --reporter compact",
    "check": "npm run typecheck && npm test && npm run build && npm run knip",
    "audit:prod": "npm audit --omit=dev",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:push-local": "node scripts/run-with-env.js .env.local -- npx drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-local": "node scripts/run-with-env.js .env.local -- npx drizzle-kit migrate",
    "db:create-local": "node scripts/run-with-env.js .env.local -- npx tsx scripts/create-env-db.ts",
    "db:check-local": "node scripts/run-with-env.js .env.local -- npx tsx scripts/check-local.ts",
    "db:reset-local-trial-monitor": "node scripts/run-with-env.js .env.local -- npx tsx scripts/reset-local-trial-monitor.ts",
    "db:wipe-local-trial-monitor": "node scripts/run-with-env.js .env.local -- npx tsx scripts/wipe-local-trial-monitor.ts",
    "db:cleanup-local-mock-market-data": "node scripts/run-with-env.js .env.local -- npx tsx scripts/cleanup-local-mock-market-data.ts",
    "db:cleanup-admin-ai-timeout-snapshots-local": "node scripts/run-with-env.js .env.local -- npx tsx scripts/cleanup-admin-ai-timeout-snapshots.ts",
    "db:status-local-postgres": "npx tsx scripts/local-postgres.ts status",
    "db:start-local-postgres": "npx tsx scripts/local-postgres.ts start",
    "db:stop-local-postgres": "npx tsx scripts/local-postgres.ts stop",
    "db:switch-local-postgres": "npx tsx scripts/local-postgres.ts switch",
    "db:add-market-runtime-config": "npx tsx scripts/add-market-runtime-config.ts",
    "db:audit-market-v2": "node scripts/run-with-env.js .env.local -- npx tsx scripts/audit-market-db-v2.ts",
    "db:audit-market-snapshot-drift": "node scripts/run-with-env.js .env.local -- npx tsx scripts/audit-market-price-snapshot-drift.ts",
    "db:seed": "npm run db:import-trials",
    "db:import-trials:dry-run": "npx tsx scripts/import-trials.ts",
    "db:import-trials": "npx tsx scripts/import-trials.ts --apply",
    "db:download-clinicaltrials-snapshot": "node scripts/run-with-env.js .env.local -- npx tsx scripts/download-clinicaltrials-gov-snapshot.ts",
    "db:export-trial-public-state": "node scripts/run-with-env.js .env.local -- npx tsx scripts/export-trial-public-state.ts",
    "db:import-trial-public-state": "npx tsx scripts/import-trial-public-state.ts --input-file",
    "db:rename-model-ids": "npx tsx scripts/rename-model-ids.ts",
    "db:purge-legacy-open-markets": "npx tsx scripts/purge-legacy-open-markets.ts",
    "db:reset-season": "npx tsx scripts/reset-season.ts",
    "db:download-public-company-reference": "npx tsx scripts/download-public-company-reference.ts",
    "db:backfill-public-sponsor-tickers": "node scripts/run-with-env.js .env.local -- npx tsx scripts/backfill-public-sponsor-tickers.ts",
    "db:export-manual-trial-outcome-queue": "node scripts/run-with-env.js .env.local -- npx tsx scripts/export-manual-trial-outcome-queue.ts",
    "db:import-manual-trial-outcomes": "node scripts/run-with-env.js .env.local -- npx tsx scripts/import-manual-trial-outcomes.ts",
    "db:sync-ai-batches-to-prod": "node scripts/run-with-env.js .env.local -- npx tsx scripts/sync-ai-batches-to-prod.ts",
    "db:extract-clinicaltrials-sponsors": "npx tsx scripts/extract-clinicaltrials-gov-sponsors.ts",
    "db:curate-clinicaltrials-sponsors": "npx tsx scripts/curate-clinicaltrials-sponsor-map.ts",
    "db:report-public-sponsors": "node scripts/run-with-env.js .env.local -- npx tsx scripts/report-public-sponsor-coverage.ts",
    "db:sync-clinicaltrials": "node scripts/run-with-env.js .env.local -- npx tsx scripts/sync-clinicaltrials-gov.ts",
    "db:sync-clinicaltrials:from-file": "node scripts/run-with-env.js .env.local -- npx tsx scripts/sync-clinicaltrials-gov.ts --input-file",
    "db:reset-season4": "node scripts/run-with-env.js .env.local -- npx tsx scripts/reset-season4.ts",
    "season4:claim-cdp-faucet": "node scripts/run-with-env.js .env.local -- npx tsx scripts/claim-season4-cdp-faucet.ts",
    "season4:deploy-contracts": "node scripts/run-with-env.js .env.local -- npx tsx scripts/deploy-season4-contracts.ts",
    "season4:deploy-contracts:toy": "node scripts/run-with-env.js .env.local -- npx tsx scripts/deploy-season4-contracts.ts --target=toy",
    "season4:fund-model-wallets": "node scripts/run-with-env.js .env.local -- npx tsx scripts/fund-season4-model-wallets.ts",
    "season4:index-onchain": "node scripts/run-with-env.js .env.local -- npx tsx scripts/index-season4-onchain.ts",
    "season4:indexer:worker": "npx tsx scripts/season4-indexer-worker.ts",
    "season4:model-cycle": "npx tsx scripts/season4-model-cycle.ts",
    "season4:model-cycle:worker": "npx tsx scripts/season4-model-cycle-worker.ts",
    "season4:smoke-market": "node scripts/run-with-env.js .env.local -- npx tsx scripts/smoke-season4-market.ts",
    "season4:seed-model-wallets": "node scripts/run-with-env.js .env.local -- npx tsx scripts/seed-season4-model-wallets.ts",
    "test:model-ids": "node --import tsx --test tests/model-id-rename.test.ts",
    "ops:check-prod-alerts": "node scripts/run-with-env.js .env.local -- npx tsx scripts/ops-check-prod-alerts.ts",
    "railway": "node scripts/run-railway.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.50.1",
    "@privy-io/node": "^0.15.0",
    "@privy-io/react-auth": "^3.22.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.4",
    "openai": "^6.34.0",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.12.0",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.48.1"
  },
  "devDependencies": {
    "@coinbase/cdp-sdk": "^1.48.0",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.5",
    "@nomicfoundation/hardhat-node-test-runner": "^3.0.13",
    "@nomicfoundation/hardhat-viem": "^3.0.5",
    "@nomicfoundation/hardhat-viem-assertions": "^3.0.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "hardhat": "^3.4.0",
    "knip": "^6.5.0",
    "postcss": "^8.5.10",
    "solc": "^0.8.34",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "axios": "1.15.0",
    "minimatch": "^9.0.7",
    "brace-expansion": "^2.0.3",
    "protobufjs": "7.5.5",
    "tmp": "0.2.5"
  }
}
