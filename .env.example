# Core Railway runtime (required in production)
# For local X OAuth testing, prefer http://127.0.0.1:3000 over localhost.
DATABASE_URL=
TOY_DATABASE_URL=
# Required in Railway. Set to `main` or `toy` to pin the deployment target.
# Leave blank locally if you want the admin switcher to control the active database.
DATABASE_TARGET=
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_VERIFICATION_KEY=

# Public site metadata
NEXT_PUBLIC_SITE_URL=https://endpointarena.com
SITE_URL=https://endpointarena.com

# Runtime tuning and ops defaults
DATABASE_POOL_MAX=1
DATABASE_PUBLIC_URL=
NEXT_PUBLIC_LOCAL_DISABLED_MODEL_IDS=
RAILWAY_APP_SERVICE=endpoint-arena-app
MAINTENANCE_MODE=false
CRASH_ALERT_COOLDOWN_MINUTES=30
MODEL_DECISION_RESPONSE_TIMEOUT_SECONDS=180
MODEL_DECISION_RESPONSE_TIMEOUT_SECONDS_GPT_5_4=180

# Local development toggles
LOCAL_DEV_ADMIN_BYPASS=0
LOCAL_DEV_X_BYPASS=0
LOCAL_DEV_X_BYPASS_EMAILS=

# Prediction providers (set at least one supported provider in Railway production)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GOOGLE_API_KEY=
FIREWORKS_API_KEY=

# Coinbase CDP Faucet (optional, used for programmatic Base Sepolia funding)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# Scheduler auth (deferred for this release; leave blank until scheduled jobs are enabled)
TRIAL_MONITOR_CRON_SECRET=
TRIAL_SYNC_CRON_SECRET=

# X OAuth (optional)
X_CLIENT_ID=
X_CLIENT_SECRET=

# Season 4 onchain (Base Sepolia)
SEASON4_CHAIN_ID=84532
BASE_SEPOLIA_RPC_URL=
SEASON4_RPC_URL=
SEASON4_INDEX_FROM_BLOCK=0
SEASON4_DEPLOYER_ADDRESS=
SEASON4_DEPLOYER_PRIVATE_KEY=
SEASON4_MARKET_MANAGER_ADDRESS=
SEASON4_FAUCET_ADDRESS=
SEASON4_COLLATERAL_TOKEN_ADDRESS=

# Optional Toy DB Season 4 contracts. If Toy DB is active, these are used
# instead of the main Season 4 contract addresses so test publishes do not
# pollute the main onchain read model.
SEASON4_TOY_CHAIN_ID=84532
SEASON4_TOY_RPC_URL=
SEASON4_TOY_INDEX_FROM_BLOCK=0
SEASON4_TOY_DEPLOYER_PRIVATE_KEY=
SEASON4_TOY_MARKET_MANAGER_ADDRESS=
SEASON4_TOY_FAUCET_ADDRESS=
SEASON4_TOY_COLLATERAL_TOKEN_ADDRESS=

SEASON4_MODEL_STARTING_BANKROLL_DISPLAY=1000
SEASON4_MODEL_WALLETS_JSON=
SEASON4_MODEL_PRIVATE_KEYS_JSON=
SEASON4_MODEL_TRADE_AMOUNT_DISPLAY=5
SEASON4_MODEL_MAX_MARKETS_PER_CYCLE=1
SEASON4_INDEXER_INTERVAL_SECONDS=30

# Email, contact, and alerting (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Endpoint Arena <noreply@endpointarena.com>"
CONTACT_ADMIN_EMAIL=
APP_HEALTH_URL=https://endpointarena.com/api/health
ALERT_LOG_WINDOW=1h
ALERT_LOG_LINES=1500
ALERT_MAX_TOTAL_ERROR_LINES=50
ALERT_MAX_DB_CONNECTIVITY_ERRORS=0
ALERT_MAX_AUTH_CALLBACK_ERRORS=10
RAILWAY_BIN=
