# Core runtime (required on Railway)
DATABASE_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://endpointarena.com
MAINTENANCE_MODE=false

# Optional site metadata
NEXT_PUBLIC_SITE_URL=https://endpointarena.com
SITE_URL=https://endpointarena.com

# Optional runtime tuning
DATABASE_POOL_MAX=1
DATABASE_PUBLIC_URL=
NEXT_PUBLIC_LOCAL_DISABLED_MODEL_IDS=
MARKET_RUN_MODEL_IDS=
RAILWAY_SERVICE_NAME=endpoint-arena-app
CRASH_ALERT_COOLDOWN_MINUTES=30
MARKET_RUN_STALE_TIMEOUT_MINUTES=20
MARKET_MODEL_RESPONSE_TIMEOUT_SECONDS=180

# Local development toggles
LOCAL_DEV_ADMIN_BYPASS=0
LOCAL_DEV_TWITTER_BYPASS=0

# Prediction providers (set at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
BASETEN_DEEPSEEK_API_KEY=
BASETEN_GLM_API_KEY=
BASETEN_KIMI_API_KEY=
MINIMAX_API_KEY=

# Scheduler auth
TRIAL_MONITOR_CRON_SECRET=
TRIAL_SYNC_CRON_SECRET=

# Twitter OAuth (optional)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Email, contact, and alerting (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Endpoint Arena <noreply@endpointarena.com>"
CONTACT_ADMIN_EMAIL=
